/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./out-tsc/app",
    "types": ["node"],
    "baseUrl": "./src",
    "paths": {
      "@app/*": ["app/*"],
      "@core/*": ["app/core/*"],
      "@domains/*": ["app/domains/*"],
      "@shared/*": ["app/shared/*"],
      "@layouts/*": ["app/layouts/*"],
      "@env/*": ["environments/*"]
    }
  },
  "include": ["src/**/*.ts", "src/app/domains/SellerReview/admin-seller-requests.component"],
  "exclude": ["src/**/*.spec.ts"]
}
